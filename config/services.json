{
  "version": 3,
  "description": "Backend services shipped in this repository (under services/).",
  "services": [
    {
      "id": "users-service",
      "path": "services/users-service",
      "language": "rust",
      "summary": "Identity, tenants, authentication",
      "ports": { "http": 8080, "grpc": 50051 }
    },
    {
      "id": "accounts-service",
      "path": "services/accounts-service",
      "language": "rust",
      "summary": "Accounts, balances, transfer orchestration",
      "ports": { "http": 8081, "grpc": 50052 }
    },
    {
      "id": "ledger-service",
      "path": "services/ledger-service",
      "language": "ruby",
      "summary": "Double-entry ledger, financial finality",
      "ports": { "http": 3000, "grpc": 9090 }
    },
    {
      "id": "audit-service",
      "path": "services/audit-service",
      "language": "rust",
      "summary": "Append-only audit trail ingest",
      "ports": { "http": 8084, "grpc": 50054 }
    }
  ]
}
