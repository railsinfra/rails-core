{
  "version": 3,
  "tracking": "https://linear.app/railsinfra/issue/RAI-5/design-monorepo-architecture-for-rails-core-services",
  "description": "Vendored backend services (normal directories under services/, not git submodules).",
  "services": [
    {
      "id": "users-service",
      "path": "services/users-service",
      "language": "rust",
      "summary": "Identity, tenants, authentication",
      "ports": { "http": 8080, "grpc": 50051 }
    },
    {
      "id": "accounts-service",
      "path": "services/accounts-service",
      "language": "rust",
      "summary": "Accounts, balances, transfer orchestration",
      "ports": { "http": 8081, "grpc": 50052 }
    },
    {
      "id": "ledger-service",
      "path": "services/ledger-service",
      "language": "ruby",
      "summary": "Double-entry ledger, financial finality",
      "ports": { "http": 3000, "grpc": 50053 }
    }
  ]
}
