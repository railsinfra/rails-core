{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "rails-core",
    "description": "Same sequence as README: gateway → register business → API key → two accounts → deposit → transfer.\n\n**Setup:** `make dev` (gateway on :8080). Import this file, set `base_url` if needed, then run **1 → 5 in order** (tests save `access_token`, `environment_id`, `api_key`, `from_account_id`, `to_account_id`).\n\nIf users-service has `INTERNAL_SERVICE_TOKEN_ALLOWLIST`, add `X-Internal-Service-Token` on sensitive routes (see `services/users-service/README.md`).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "access_token", "value": "" },
    { "key": "environment_id", "value": "" },
    { "key": "api_key", "value": "" },
    { "key": "from_account_id", "value": "" },
    { "key": "to_account_id", "value": "" },
    { "key": "audit_correlation_id", "value": "" },
    { "key": "audit_deposit_idempotency_key", "value": "audit-deposit-1" },
    { "key": "audit_transfer_idempotency_key", "value": "audit-transfer-1" },
    { "key": "audit_transaction_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Register business",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const suffix = `${Date.now()}-${Math.floor(Math.random() * 100000)}`;",
              "pm.collectionVariables.set('demo_business_name', `Demo Co ${suffix}`);",
              "pm.collectionVariables.set('demo_business_website', `https://demo-${suffix}.example.com`);",
              "pm.collectionVariables.set('demo_admin_first_name', 'Ada');",
              "pm.collectionVariables.set('demo_admin_last_name', `User${Math.floor(Math.random() * 10000)}`);",
              "pm.collectionVariables.set('demo_admin_email', `ada+${suffix}@example.com`);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code !== 200 && pm.response.code !== 201) { return; }",
              "try {",
              "  const j = pm.response.json();",
              "  if (j.access_token) pm.collectionVariables.set('access_token', j.access_token);",
              "  if (j.selected_environment_id) pm.collectionVariables.set('environment_id', j.selected_environment_id);",
              "} catch (e) { console.warn(e); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{demo_business_name}}\",\n  \"website\": \"{{demo_business_website}}\",\n  \"admin_first_name\": \"{{demo_admin_first_name}}\",\n  \"admin_last_name\": \"{{demo_admin_last_name}}\",\n  \"admin_email\": \"{{demo_admin_email}}\",\n  \"admin_password\": \"SecurePass123!\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{base_url}}/users/api/v1/business/register",
        "description": "Generates unique business/admin data on every run to avoid duplicate-email conflicts."
      },
      "response": []
    },
    {
      "name": "2. Create server API key",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code !== 200 && pm.response.code !== 201) { return; }",
              "try {",
              "  const j = pm.response.json();",
              "  if (j.key) pm.collectionVariables.set('api_key', j.key);",
              "} catch (e) { console.warn(e); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" },
          { "key": "X-Environment-Id", "value": "{{environment_id}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{base_url}}/users/api/v1/api-keys",
        "description": "Plaintext `key` is returned once; saved to collection variable `api_key`."
      },
      "response": []
    },
    {
      "name": "3a. Create account (holder A)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code !== 200 && pm.response.code !== 201) { return; }",
              "try {",
              "  const j = pm.response.json();",
              "  if (j.id) pm.collectionVariables.set('from_account_id', j.id);",
              "} catch (e) { console.warn(e); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{api_key}}" },
          { "key": "X-Environment", "value": "sandbox" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"account_type\": \"checking\",\n  \"email\": \"holder-a+{{$timestamp}}{{$randomInt}}@example.com\",\n  \"first_name\": \"A\",\n  \"last_name\": \"One\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{base_url}}/accounts/api/v1/accounts"
      },
      "response": []
    },
    {
      "name": "3b. Create account (holder B)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code !== 200 && pm.response.code !== 201) { return; }",
              "try {",
              "  const j = pm.response.json();",
              "  if (j.id) pm.collectionVariables.set('to_account_id', j.id);",
              "} catch (e) { console.warn(e); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{api_key}}" },
          { "key": "X-Environment", "value": "sandbox" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"account_type\": \"checking\",\n  \"email\": \"holder-b+{{$timestamp}}{{$randomInt}}@example.com\",\n  \"first_name\": \"B\",\n  \"last_name\": \"Two\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{base_url}}/accounts/api/v1/accounts"
      },
      "response": []
    },
    {
      "name": "4. Deposit (first account)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Environment", "value": "sandbox" },
          { "key": "Idempotency-Key", "value": "readme-deposit-1" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 100000\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{base_url}}/accounts/api/v1/accounts/{{from_account_id}}/deposit",
        "description": "Amount in minor units (e.g. cents)."
      },
      "response": []
    },
    {
      "name": "5. Transfer to second account",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Environment", "value": "sandbox" },
          { "key": "Idempotency-Key", "value": "readme-transfer-1" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"to_account_id\": \"{{to_account_id}}\",\n  \"amount\": 5000\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{base_url}}/accounts/api/v1/accounts/{{from_account_id}}/transfer"
      },
      "response": []
    },
    {
      "name": "Audit",
      "item": [
        {
          "name": "A1. Audit service health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/audit/health",
            "description": "Confirms audit-service is reachable through gateway before mutation checks."
          },
          "response": []
        },
        {
          "name": "A2. Deposit with explicit correlation id",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const cid = `audit-deposit-${Date.now()}`;",
                  "pm.collectionVariables.set('audit_correlation_id', cid);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const cid = pm.collectionVariables.get('audit_correlation_id');",
                  "pm.test('response echoes correlation id', function () {",
                  "  pm.expect(pm.response.headers.get('x-correlation-id')).to.eql(cid);",
                  "});",
                  "console.log('Audit verify (deposit): correlation_id=', cid, 'idempotency_key=', pm.collectionVariables.get('audit_deposit_idempotency_key'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Environment", "value": "sandbox" },
              { "key": "Idempotency-Key", "value": "{{audit_deposit_idempotency_key}}" },
              { "key": "X-Correlation-Id", "value": "{{audit_correlation_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/accounts/api/v1/accounts/{{from_account_id}}/deposit",
            "description": "Use the saved `audit_correlation_id` to confirm: accounts start/finish logs + audit append success in audit-service logs."
          },
          "response": []
        },
        {
          "name": "A3. Transfer with explicit correlation id",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const cid = `audit-transfer-${Date.now()}`;",
                  "pm.collectionVariables.set('audit_correlation_id', cid);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const cid = pm.collectionVariables.get('audit_correlation_id');",
                  "pm.test('response echoes correlation id', function () {",
                  "  pm.expect(pm.response.headers.get('x-correlation-id')).to.eql(cid);",
                  "});",
                  "console.log('Audit verify (transfer): correlation_id=', cid, 'idempotency_key=', pm.collectionVariables.get('audit_transfer_idempotency_key'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Environment", "value": "sandbox" },
              { "key": "Idempotency-Key", "value": "{{audit_transfer_idempotency_key}}" },
              { "key": "X-Correlation-Id", "value": "{{audit_correlation_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to_account_id\": \"{{to_account_id}}\",\n  \"amount\": 500\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/accounts/api/v1/accounts/{{from_account_id}}/transfer",
            "description": "Use the saved `audit_correlation_id` to confirm: accounts start/finish logs + audit append success in audit-service logs."
          },
          "response": []
        },
        {
          "name": "A4. Validate existing transaction (read-only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const cid = pm.collectionVariables.get('audit_correlation_id');",
                  "const tx = pm.collectionVariables.get('audit_transaction_id');",
                  "console.log('Audit verify (existing tx): correlation_id=', cid, 'transaction_id=', tx, 'endpoint=/accounts/api/v1/transactions/' + tx);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Environment", "value": "sandbox" },
              { "key": "X-Correlation-Id", "value": "{{audit_correlation_id}}" }
            ],
            "url": "{{base_url}}/accounts/api/v1/transactions/{{audit_transaction_id}}",
            "description": "Read-only lookup for an existing transaction. Set `audit_transaction_id` and matching `audit_correlation_id` from your real logs, then grep logs across services using those values to confirm audit emission and downstream persistence."
          },
          "response": []
        }
      ]
    }
  ]
}
