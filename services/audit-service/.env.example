# Copy to .env: cp .env.example .env
#
# Required: dedicated audit database (see repo docs/audit-trail-architecture.md)
AUDIT_DATABASE_URL=postgresql://user:password@host:5432/audit_db?sslmode=require

# Optional: falls back to DATABASE_URL if AUDIT_DATABASE_URL is unset
# DATABASE_URL=postgresql://...

SERVER_ADDR=0.0.0.0:8080
GRPC_PORT=50054
RUST_LOG=info
ENVIRONMENT=development

# Optional
# SENTRY_DSN=
