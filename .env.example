# Copy to .env in this repository root.
# Databases are external (e.g. Neon); no local Postgres required for compose.

USERS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/users_db
ACCOUNTS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/accounts_db
LEDGER_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ledger_db

# Optional
RUST_LOG=info
