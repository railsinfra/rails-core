# Copy to .env in this repository root.
# Databases are external (e.g. Neon); no local Postgres container is defined in compose.
#
# Option A — manual URLs: replace the hostname after @ with your real Postgres host
# (do not use the literal word HOST — it is a valid-looking placeholder that breaks DNS).
#
# Option B — Neon auto-provision: set NEON_API_KEY and run `make bootstrap` or `make dev`.
# Bootstrap creates/finds Neon project RAILS_CORE_NEON_PROJECT_NAME (default rails-core-dev),
# ensures databases users-db, accounts-db, ledger-db, audit-db exist, and merges URLs into .env.

USERS_DATABASE_URL=postgresql://USER:PASSWORD@YOUR_POSTGRES_HOST:5432/users_db
ACCOUNTS_DATABASE_URL=postgresql://USER:PASSWORD@YOUR_POSTGRES_HOST:5432/accounts_db
LEDGER_DATABASE_URL=postgresql://USER:PASSWORD@YOUR_POSTGRES_HOST:5432/ledger_db

# Dedicated Postgres for append-only audit events (Neon audit-db when using bootstrap; see docs/audit-trail-architecture.md).
AUDIT_DATABASE_URL=postgresql://USER:PASSWORD@YOUR_POSTGRES_HOST:5432/audit_db

# Optional — append-only audit ingest gRPC. Rust services (tonic) use http://host:port; ledger-service uses host:port only.
# AUDIT_GRPC_URL=http://127.0.0.1:50054

# Optional — per-append RPC deadline (ms) from users/accounts/ledger to audit-service. Remote DB latency (Neon) often exceeds 400ms.
# AUDIT_APPEND_TIMEOUT_MS=5000

NEON_API_KEY=your-neon-api-key
# Optional — shorten Neon console links in bootstrap (Bitly preferred; otherwise is.gd, no key).
# Set NEON_CONSOLE_NO_PUBLIC_SHORTENER=yes to disable is.gd and only use Bitly (or long URLs).
# BITLY_ACCESS_TOKEN=
# BITLY_GROUP_GUID=   # optional; default group from GET /v4/groups if omitted
# NEON_CONSOLE_NO_PUBLIC_SHORTENER=yes
# NEON_REGION_ID=aws-us-east-1
# RAILS_CORE_NEON_PROJECT_NAME=rails-core-dev

# Optional — logging for Rust services in Docker Compose
RUST_LOG=info

# Optional — `make dev` waits for gateway health (default 900s). First Rust compile can exceed that.
# DEV_WAIT_TIMEOUT_SEC=1200
# DEV_WAIT_INTERVAL_SEC=5

# Optional — only when running Rust services on the host (not needed for `make dev`):
# ACCOUNTS_GRPC_URL=http://127.0.0.1:9090
# USERS_GRPC_URL=http://127.0.0.1:50051
# LEDGER_GRPC_URL=http://127.0.0.1:50053

# Optional — k6 load tests (export when running `make k6-smoke`; not read by compose).
# K6_API_KEY=
# K6_ORGANIZATION_ID=   # business UUID for account create
# K6_USERS_BASE_URL=http://127.0.0.1:8080/users
# K6_ACCOUNTS_BASE_URL=http://127.0.0.1:8080/accounts
# K6_ENVIRONMENT=sandbox
# K6_USER_PASSWORD=password123!
# For high-volume money routes in compose, consider raising accounts-service limits, e.g.:
# ACCOUNTS_MONEY_RATE_LIMIT_MAX=100000
# ACCOUNTS_TRUSTED_PROXY_IPS=<gateway_ip_seen_by_accounts_service>

# Optional — users-service sensitive routes (register/login) require this header when set:
# INTERNAL_SERVICE_TOKEN_ALLOWLIST=your-dev-token
